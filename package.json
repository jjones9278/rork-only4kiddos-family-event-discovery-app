{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "npx expo start --lan",
    "start:tunnel": "npx expo start --tunnel",
    "start-web": "EXPO_NO_TELEMETRY=1 EXPO_ROUTER_APP_ROOT=./app npx expo start --web --port 5000 --host tunnel",
    "build:web": "EXPO_NO_TELEMETRY=1 EXPO_ROUTER_APP_ROOT=./app bun --bun ./node_modules/expo/bin/cli export --platform web --output-dir dist",
    "start:prod": "bunx serve dist -s -l 5000",
    "dev:server": "bun run backend/server.ts",
    "start:server": "bun run backend/server.ts",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "dev:all": "concurrently -k \"bun run backend/server.ts\" \"expo start\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hono/trpc-server": "^0.4.0",
    "@nkzw/create-context-hook": "^1.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.6",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@stripe/react-stripe-js": "^4.0.2",
    "@stripe/stripe-js": "^7.9.0",
    "@stripe/stripe-react-native": "0.38.6",
    "@tanstack/react-query": "^5.87.4",
    "@trpc/client": "^11.5.1",
    "@trpc/react-query": "^11.5.1",
    "@trpc/server": "^11.5.1",
    "@types/uuid": "^11.0.0",
    "@ungap/structured-clone": "^1.3.0",
    "expo": "^54",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.3.0",
    "firebase-admin": "^13.5.0",
    "hono": "^4.9.7",
    "lucide-react-native": "^0.475.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "serve": "^14.2.5",
    "stripe": "^18.5.0",
    "superjson": "^2.2.2",
    "uuid": "^13.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
